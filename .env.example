# Plantastic development environment
#
# Copy to .env and adjust as needed:
#   cp .env.example .env
#
# Alternative: use Doppler to inject secrets automatically:
#   doppler run -- cargo run -p plantastic-api

# ─── Database ──────────────────────────────────────────────────
# Local Docker Compose (default)
DATABASE_URL=postgres://plantastic:plantastic@localhost:5432/plantastic
#
# Neon direct (fastest for single-connection workloads):
# DATABASE_URL=postgres://user:pass@ep-xxx.us-west-2.aws.neon.tech/plantastic?sslmode=require&sslnegotiation=direct
#
# Neon pooled (PgBouncer transaction mode — use for Lambda):
# DATABASE_URL=postgres://user:pass@ep-xxx-pooler.us-west-2.aws.neon.tech/plantastic?sslmode=require&sslnegotiation=direct&statement_cache_size=0

# Separate database for tests
TEST_DATABASE_URL=postgres://plantastic:plantastic@localhost:5432/plantastic_test

# ─── Valkey (Redis-compatible cache) ───────────────────────────
VALKEY_URL=redis://localhost:6379

# ─── API ───────────────────────────────────────────────────────
PORT=3000
RUST_LOG=info

# ─── S3 / Object Storage ──────────────────────────────────────
S3_BUCKET=plantastic-dev
S3_ENDPOINT=http://localhost:4566
AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ─── Frontend (web/) ──────────────────────────────────────────
# Set to "true" to use mock API data without a running backend
VITE_MOCK_API=false
# API_URL is used by vite dev proxy (defaults to http://localhost:3000)
# API_URL=http://localhost:3000
